  },
  "bugs": {
    "url": "https://github.com/abnersajr/mcp-readedit/issues"
  },
  "homepage": "https://github.com/abnersajr/mcp-readedit#readme",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "better-sqlite3": "^12.9.0"
